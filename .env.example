DEEPSEEK_API_KEY=sk-xxxxxx
LLM_PROVIDER=deepseek
LLM_MODEL_ID=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com


TAVILY_API_KEY=tvly-xxxxx

# ========== 本地模型（可选，当 LLM_PROVIDER=ollama 或 lmstudio 时使用） ==========
# LOCAL_LLM=llama3:8b
# OLLAMA_BASE_URL=http://localhost:11434
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ========== 笔记功能 ==========
ENABLE_NOTES=true
NOTES_WORKSPACE=./tutor_notes

# ========== 对话与生成参数 ==========
MAX_HISTORY_TURNS=10
LLM_TEMPERATURE=0.2

SSL_CERT_FILE=


# LeetCode MCP and API
ENABLE_LEETCODE_MCP=true
LEETCODE_SITE=cn
LEETCODE_GRAPHQL_URL=https://leetcode.cn/graphql
LEETCODE_PROBLEM_URL_BASE=https://leetcode.cn/problems
LEETCODE_MCP_COMMAND=node
LEETCODE_MCP_ARGS="build/index.js --site cn"
LEETCODE_MCP_CWD=xxxxxxx